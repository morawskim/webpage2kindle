{
  # Debug
  {$CADDY_DEBUG}

  metrics {
    per_host
  }

  frankenphp {
    #worker /path/to/your/worker.php
    {$FRANKENPHP_CONFIG}
    max_requests {$MAX_REQUESTS:10}
  }
}

{$SERVER_NAME::80} {
    log
    root {$SERVER_ROOT:public/}
    encode zstd br gzip
    tracing {
        span web-request
    }

    mercure {
        # Publisher JWT key
        publisher_jwt {$MERCURE_PUBLISHER_JWT_KEY}
        # Subscriber JWT key
        subscriber_jwt {$MERCURE_SUBSCRIBER_JWT_KEY}
        # Allow anonymous subscribers (double-check that it's what you want)
        anonymous
    }

    php_server {
        #worker /path/to/your/worker.php
    }
}
