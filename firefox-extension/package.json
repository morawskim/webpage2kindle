{
  "scripts": {
    "build": "webpack --config webpack-web-extension.config.mjs",
    "start:firefox": "web-ext run  --source-dir ./dist/",
    "start:chrome": "web-ext run --verbose -t chromium --chromium-binary=/usr/bin/google-chrome --source-dir ./dist/",
    "sign": "web-ext sign"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.5",
    "copy-webpack-plugin": "^14.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "web-ext": "^10.1.0",
    "web-ext-plugin": "^2.13.0",
    "webextension-polyfill": "^0.12.0",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  }
}
